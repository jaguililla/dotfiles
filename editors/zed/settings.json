// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "language_models": {
    "openai_compatible": {
      "MiniMax": {
        "api_url": "https://api.minimax.io/v1",
        "available_models": [
          {
            "name": "MiniMax-M2.5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": true,
  },
  "outline_panel": {
    "indent_size": 15.0,
  },
  "preview_tabs": {
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": true,
  },
  "buffer_font_features": {
    "calt": false,
  },
  "buffer_line_height": "standard",
  "disable_ai": false,
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
      "min_column": 70,
    },
  },
  "use_system_window_tabs": true,
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_sign_in": false,
  },
  "show_whitespaces": "boundary",
  "minimap": {
    "max_width_columns": 100,
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 1,
    "folds": false,
  },
  "relative_line_numbers": "enabled",
  "agent": {
    "tool_permissions": {
      "tools": {
        "move_path": {
          "default": "allow",
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://pkg\\.go\\.dev",
            },
          ],
        },
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^printf\\b",
            },
          ],
        },
      },
    },
    "default_model": {
      "provider": "MiniMax",
      "model": "MiniMax-M2.5",
    },
    "enabled": true,
    "single_file_review": false,
    "model_parameters": [],
    "enable_feedback": false,
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "file_scan_exclusions": [
    "**/.zig-cache",
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
  ],
  "telemetry": {
    "metrics": false,
  },
  "wrap_guides": [100],
  "vim_mode": true,
  "ui_font_size": 15,
  "buffer_font_size": 12,
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 12.75,
    "line_height": {
      "custom": 1.25,
    },
  },
  "project_panel": {
    "folder_icons": true,
    "hide_hidden": true,
    "entry_spacing": "standard",
    "indent_size": 15.0,
    "indent_guides": {
      "show": "never",
    },
    "hide_root": true,
  },
  "autosave": "on_focus_change",
  "preferred_line_length": 100,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
    "code_actions": true,
  },
  "profiles": {
    "big": {
      "settings": {
        "ui_font_size": 18,
        "buffer_font_size": 15,
        "terminal": {
          "font_size": 15
        }
      }
    },
  },
  "languages": {
    "HTML": {
      "formatter": "language_server",
      "format_on_save": "off",
    },
    "XML": {
      "format_on_save": "off",
    },
    "Java": {
      "language_servers": ["jdtls"],
      "formatter": "language_server",
      "format_on_save": "off",
    },
  },
  "lsp": {
    "vscode-html-language-server": {
      "settings": {
        "html": {
          "format": {
            "indentInnerHtml": false,
            "contentUnformatted": "svg,script",
          },
        },
      },
    },
    "jdtls": {
      "settings": {
        "initialization_options": {
          "settings": {
            "java": {
              "java_home": "$JAVA_HOME",
              "configuration": {
                "updateBuildConfiguration": "interactive",
              },
              "import": {
                "gradle": {
                  "enabled": false,
                },
                "maven": {
                  "enabled": true,
                },
                "exclusions": [
                  "**/node_modules/**",
                  "**/.metadata/**",
                  "**/archetype-resources/**",
                  "**/META-INF/maven/**",
                  "/**/test/**",
                ],
              },
              "referencesCodeLens": {
                "enabled": true,
              },
              "signatureHelp": {
                "enabled": true,
              },
              "implementationCodeLens": "all",
              "format": {
                "enabled": true,
              },
              "saveActions": {
                "organizeImports": true,
              },
              "autobuild": {
                "enabled": true,
              },
              "completion": {
                "favoriteStaticMembers": ["org.junit.jupiter.api.Assertions.*"],
                "importOrder": ["java", "javax", "com", "org"],
              },
            },
          },
        },
      },
    },
  },
}
